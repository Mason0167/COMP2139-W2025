@model COMP2139_ICE1.Areas.Admin.Models.ViewModels.ManageUserRolesViewModel

@{
    // Specifies the layout file for this view.
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@*
    This view allows an administrator to manage the roles assigned to a specific user.
    It displays the user's email, all available roles, and highlights roles currently assigned to the user.
    Administrators can select/deselect roles and save the changes.
*@
<h2>Manage Roles for @Model.Email</h2>

<form asp-area="Admin" asp-controller="Users" asp-action="Manage" method="post">

    @* AntiForgeryToken is crucial for preventing Cross-Site Request Forgery (CSRF) attacks. *@
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="UserId" />
    <input type="hidden" name="UserId" value="@Model.UserId" />

    <div class="form-group">
        <label>Select Roles</label>
        @foreach (var role in Model.AvailableRoles)
        {
            <div class="form-check">
                <input class="form-check-input"
                       type="checkbox"
                       name="SelectedRoles"
                       value="@role"
                       @(Model.AssignedRoles.Contains(role) ? "checked" : "") />
                <label class="form-check-label">@role</label>
            </div>
        }
    </div>

    <button class="btn btn-success mt-3" type="submit">Save</button>
    <a href="@Url.Action("Index", "Users", new { area = "Admin" })" class="btn btn-secondary mt-3 ms-2">Cancel</a>
</form>